{
  "expo": {
    "name": "TESS AI",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Attach photos of questions to ask TESS.",
        "NSCameraUsageDescription": "Snap textbook questions to solve with TESS.",
        "NSMicrophoneUsageDescription": "Speak your question to TESS."
      },
      "bundleIdentifier": "com.emergent.tesssmarttutor.draoh7"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE"
      ],
      "package": "com.emergent.tesssmarttutor.draoh7"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos of questions to ask TESS."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
